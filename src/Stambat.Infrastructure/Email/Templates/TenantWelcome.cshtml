@using Stambat.Infrastructure.Email.Models
@model TenantWelcomeEmailModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Welcome to Stambat - @Model.BusinessName</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f8f7f6; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">

    <div style="background-color: #f8f7f6; padding: 40px 20px;">
        
        <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 16px; border: 1px solid rgba(214, 170, 49, 0.1); overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);">
            
            <div style="padding: 24px 32px; border-bottom: 1px solid rgba(214, 170, 49, 0.1); display: flex; justify-content: space-between; align-items: center;">
                <div style="font-size: 24px; font-weight: bold; color: #0f172a;">
                    <span style="color: #d6aa31;">◆</span> Stambat
                </div>
                <div style="color: #d6aa31; font-size: 24px;">🎉</div>
            </div>

            <div style="padding: 20px 20px 0 20px; text-align: center;">
                <div style="width: 100%; height: 220px; background: #000000; background: linear-gradient(180deg, #000000 0%, #d6aa31 100%); border-radius: 48px; overflow: hidden; position: relative;">
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuA2TLCrZZdNmPeX_yoz9m2Lnryl90Mg_DVt3fxdDTVwr0ia9kw8qU8Gfw2VD56GhXbnDHy-sQ4eu2HBjsTx8_uYEbeIkt9cMPDjUb1PdjlRBJW1hncMawTaMljl-THcBWme25hAEEJadfJwN1dfNUMGK_Tbp0AHzwDhDW2Q1XuWMxiZlQdCRqisrHu3XkbY9xs0CRx-wOD2OHTVmQC1hqFjOCP8OPj-gKJuaw99GiYlXa7m4O4BXK_rFPDbnHajN5QuOYgKiNJt8SU" 
                         alt="Welcome to Stambat" 
                         style="width: 100%; height: 100%; object-fit: cover; display: block; opacity: 0.7;" />
                    <div style="position: absolute; bottom: 30px; left: 30px; text-align: left;">
                        <h1 style="color: #ffffff; margin: 0; font-size: 32px; font-weight: bold;">Welcome to Stambat!</h1>
                    </div>
                </div>
            </div>

            <div style="padding: 32px;">
                <p style="color: #d6aa31; font-weight: 600; text-transform: uppercase; font-size: 12px; letter-spacing: 0.1em; margin: 0 0 8px 0;">Getting Started</p>
                <h2 style="color: #0f172a; font-size: 24px; margin: 0 0 12px 0;">Hi @Model.OwnerName!</h2>
                <p style="color: #475569; font-size: 16px; line-height: 1.6; margin: 0 0 32px 0;">
                    We're thrilled to have <span style="font-weight: bold; color: #d6aa31;">@Model.BusinessName</span> join our community! Your account is officially active and ready to help your business grow through meaningful customer connections.
                </p>

                <div style="background-color: #fcfbf9; padding: 24px; border-radius: 16px; margin-bottom: 32px;">
                    <p style="color: #0f172a; font-weight: bold; font-size: 18px; margin: 0 0 20px 0;">Quick Start Checklist</p>
                    
                    <div style="margin-bottom: 16px; display: flex; align-items: flex-start;">
                        <div style="color: #d6aa31; margin-right: 12px; font-size: 18px;">✔</div>
                        <div>
                            <p style="margin: 0; font-weight: 600; color: #0f172a; font-size: 15px;">Create your first loyalty card</p>
                            <p style="margin: 0; color: #64748b; font-size: 13px;">Set up stamps and rewards in minutes</p>
                        </div>
                    </div>

                    <div style="margin-bottom: 16px; display: flex; align-items: flex-start;">
                        <div style="color: #d6aa31; margin-right: 12px; font-size: 18px;">✔</div>
                        <div>
                            <p style="margin: 0; font-weight: 600; color: #0f172a; font-size: 15px;">Invite your team members</p>
                            <p style="margin: 0; color: #64748b; font-size: 13px;">Grant access to staff to issue stamps</p>
                        </div>
                    </div>

                    <div style="display: flex; align-items: flex-start;">
                        <div style="color: #d6aa31; margin-right: 12px; font-size: 18px;">✔</div>
                        <div>
                            <p style="margin: 0; font-weight: 600; color: #0f172a; font-size: 15px;">Explore the dashboard analytics</p>
                            <p style="margin: 0; color: #64748b; font-size: 13px;">See how your customers are engaging</p>
                        </div>
                    </div>
                </div>

                <div style="text-align: center;">
                    <a href="@Model.DashboardLink" target="_blank" 
                       style="background-color: #d6aa31; color: #201c12; padding: 18px 48px; font-size: 18px; font-weight: bold; text-decoration: none; border-radius: 12px; display: inline-block; width: 80%;">
                        Go to My Dashboard →
                    </a>
                    <p style="color: #64748b; font-size: 14px; margin-top: 24px;">
                        Need help? <a href="#" style="color: #d6aa31; text-decoration: none; font-weight: 500;">Check out our guide</a>
                    </p>
                </div>
            </div>

            <footer style="background-color: rgba(214, 170, 49, 0.05); padding: 32px; text-align: center; border-top: 1px solid rgba(214, 170, 49, 0.1);">
                <p style="margin: 0 0 8px 0; color: #94a3b8; font-size: 10px; text-transform: uppercase; letter-spacing: 0.2em; font-weight: bold;">
                    © 2026 Stambat SaaS Inc.
                </p>
                <p style="margin: 0; color: #94a3b8; font-size: 11px;">
                    123 Innovation Drive, Suite 400, San Francisco, CA 94105
                </p>
            </footer>

        </div>
    </div>
</body>
</html>