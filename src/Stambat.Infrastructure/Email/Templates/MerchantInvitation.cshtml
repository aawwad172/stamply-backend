<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta content="width=device-width, initial-scale=1.0" name="viewport" />
    <title>Join the Team on Stambat</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f8f7f6; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif; color: #0f172a;">
    <div style="width: 100%; background-color: #f8f7f6; padding: 40px 0;">
        
        <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 16px; border: 1px solid rgba(214, 170, 49, 0.15); overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
            
            <div style="padding: 24px 40px; border-bottom: 1px solid rgba(214, 170, 49, 0.15); display: flex; align-items: center;">
                <span style="color: #d6aa31; font-size: 28px; font-weight: bold; margin-right: 10px;">◆</span>
                <span style="font-size: 24px; font-weight: 700; color: #0f172a;">Stambat</span>
            </div>

            <div style="padding: 24px;">
                <div style="width: 100%; height: 200px; border-radius: 12px; background-color: rgba(214, 170, 49, 0.1); background-image: url('https://images.unsplash.com/photo-1522071820081-009f0129c71c?auto=format&fit=crop&w=600&q=80'); background-size: cover; background-position: center; border: 1px solid rgba(214, 170, 49, 0.2);"></div>
            </div>

            <div style="padding: 0 40px 40px 40px; text-align: center;">
                <h1 style="font-size: 28px; font-weight: 700; margin: 0 0 16px 0; line-height: 1.2;">
                    You've been invited to join <span style="color: #d6aa31;">@Model.TenantName</span> on Stambat
                </h1>
                <p style="font-size: 16px; color: #475569; line-height: 1.6; margin: 0 auto 32px auto; max-width: 440px;">
                    Welcome to the team! Your workspace is ready. Join now to start managing loyalty cards and connecting with your customers.
                </p>

                <div style="display: inline-block;">
                    <a href="@Model.InvitationLink" style="display: inline-block; background-color: #d6aa31; color: #ffffff; text-decoration: none; padding: 16px 48px; border-radius: 9999px; font-weight: 700; font-size: 18px; box-shadow: 0 10px 15px -3px rgba(214, 170, 49, 0.3);">
                        Accept Invitation
                    </a>
                </div>

                <div style="margin-top: 40px; padding-top: 30px; border-top: 1px solid rgba(214, 170, 49, 0.15);">
                    <p style="font-size: 13px; color: #94a3b8; margin-bottom: 20px; line-height: 1.5;">
                        This invitation was sent to @Model.Email. If you weren't expecting this, you can safely ignore this email.
                    </p>
                    <div style="font-size: 14px; font-weight: 500;">
                        <a href="#" style="color: #d6aa31; text-decoration: none; margin: 0 10px;">Help Center</a>
                        <a href="#" style="color: #d6aa31; text-decoration: none; margin: 0 10px;">Privacy Policy</a>
                        <a href="#" style="color: #d6aa31; text-decoration: none; margin: 0 10px;">Terms</a>
                    </div>
                </div>
            </div>
        </div>

        <div style="text-align: center; color: #94a3b8; font-size: 12px; margin-top: 24px;">
            <p>© 2026 Stambat. All rights reserved.</p>
        </div>
    </div>
</body>
</html>