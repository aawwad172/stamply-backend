@using Stambat.Infrastructure.Email.Models
@model VerificationEmailModel

<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify your email - Stambat</title>
</head>
<body style="margin: 0; padding: 0; background-color: #f1f5f9; font-family: 'Segoe UI', Roboto, Helvetica, Arial, sans-serif;">
    
    <div style="background-color: #f1f5f9; padding: 40px 20px;">
        
        <div style="max-width: 600px; margin: 0 auto; background-color: #ffffff; border-radius: 16px; border: 1px solid #e2e8f0; overflow: hidden; box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.1);">
            
            <div style="padding: 24px 32px; border-bottom: 1px solid #f1f5f9;">
                <span style="font-size: 24px; font-weight: bold; color: #0f172a;">
                    <span style="color: #d6aa31;">◆</span> Stambat
                </span>
            </div>

            <div style="padding: 32px; text-align: center;">

            <div style="padding: 0 32px 32px 32px; text-align: center;">
                <div style="width: 100%; max-width: 500px; height: 220px; margin: 0 auto; 
                            background: #000000; 
                            background: linear-gradient(180deg, #000000 0%, #d6aa31 100%); 
                            border-radius: 48px; overflow: hidden; display: block; border: 1px solid #d6aa31;">
                    
                    <img src="https://lh3.googleusercontent.com/aida-public/AB6AXuAq6SHG1993HZ5pXNRxRMBuiSn1-wnDBCD76LdsPXskjF5SnX-LupXmMmiY4QB4hZGVYiOgSEec94gTAPIXMMkKCWxd8f0rzWfpfe1sr5aU5Lwb9Uc1moIbor28tcuSt0AngJp3QzBTJ4l77oYA0OV51kB0NYLNc7G7PwMh4WbmPkgKvQoPsxI0D6_Z_245k6EtimhP12hl1ruEAbsidlRucvmSzA3RJ1wgOmbeJ0yE28BdKThVVrZB43h0icOlYcwekKT9P-2mujg" 
                        alt="Stambat Rewards" 
                        style="width: 100%; height: 100%; object-fit: cover; display: block; opacity: 0.9;" />
                </div>
            </div>

                <h1 style="margin: 0 0 16px 0; color: #0f172a; font-size: 28px; font-weight: bold;">Verify your email address</h1>
                
                <p style="margin: 0 0 24px 0; color: #475569; font-size: 16px; line-height: 1.6;">
                    Hi <strong>@Model.UserName</strong>! Thanks for signing up for Stambat. 
                    We're excited to have you on board. To complete your account setup and start your journey, please verify your email address.
                </p>

                <div style="padding: 10px 0;">
                    <a href="@Model.VerificationLink" target="_blank" 
                       style="background-color: #d6aa31; color: #ffffff; padding: 16px 36px; font-size: 18px; font-weight: bold; text-decoration: none; border-radius: 9999px; display: inline-block;">
                        Verify Email Address
                    </a>
                </div>

                <p style="margin: 32px 0 0 0; color: #94a3b8; font-size: 13px; line-height: 1.5;">
                    If the button above doesn't work, copy and paste this link into your browser:<br />
                    <a href="@Model.VerificationLink" style="color: #d6aa31; text-decoration: underline; word-break: break-all;">@Model.VerificationLink</a>
                </p>
            </div>

            <div style="padding: 32px; background-color: #f8fafc; border-top: 1px solid #f1f5f9; color: #94a3b8; font-size: 12px; text-align: center;">
                <p style="margin: 0 0 8px 0;">© 2026 Stambat Inc.</p>
                <p style="margin: 0; line-height: 1.4;">You received this email because you signed up for Stambat. If you did not create an account, please ignore this email.</p>
            </div>
            
        </div>
    </div>
</body>
</html>